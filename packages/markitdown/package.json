{
  "name": "@repo/markitdown",
  "version": "0.1.0",
  "description": "Universal document-to-Markdown converter. TypeScript port of Microsoft MarkItDown supporting PDF, DOCX, XLSX, PPTX, EPUB, HTML, CSV, and 10+ formats.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "^1.28.0",
    "cheerio": "^1.1.2",
    "exifr": "^7.1.3",
    "fast-xml-parser": "^5.5.10",
    "file-type": "^22.0.0",
    "iconv-lite": "^0.7.0",
    "jschardet": "^3.1.4",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.2",
    "music-metadata": "^11.12.3",
    "pdfjs-dist": "^5.6.205",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "xlsx": "^0.18.5",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.5.0"
  }
}
