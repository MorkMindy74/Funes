# ═══════════════════════════════════════════════════════════════════
# Funes Self-Hosted — Environment Configuration
# Copy to .env and customize as needed
# ═══════════════════════════════════════════════════════════════════

# Database password (default: funes_dev)
DB_PASSWORD=funes_dev

# Auth secret — CHANGE THIS IN PRODUCTION
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-in-production

# ─── Optional: Local LLM via Ollama ─────────────────────────────────
# Start with: docker compose --profile with-ollama up
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2

# ─── Optional: Advanced Web Scraping via Firecrawl ───────────────────
# Start with: docker compose --profile with-firecrawl up
# Scrapes JS-rendered pages (SPAs), removes boilerplate automatically
# FIRECRAWL_URL=http://firecrawl:3003

# ─── Optional: OCR for Images & Scanned Documents ──────────────────
# Option A: Ollama Vision (uses existing Ollama with a vision model)
#   OCR_PROVIDER=ollama-ocr
#   OLLAMA_OCR_MODEL=llava           # or: llama3.2-vision, moondream, bakllava
#
# Option B: Chandra OCR service (dedicated OCR microservice)
#   OCR_PROVIDER=chandra
#   CHANDRA_URL=http://chandra:8000

# ─── Optional: OAuth Connections (Google Drive, Notion, OneDrive) ────
# Create OAuth credentials in each provider's developer console.
# Redirect URI for all: http://localhost:3001/v3/connections/callback
#
# Google Drive: https://console.cloud.google.com/apis/credentials
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
#
# Notion: https://www.notion.so/my-integrations
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
#
# OneDrive: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=

# ─── Optional: Analytics ─────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_SENTRY_DSN=

# ─── Optional: AI Chat Providers ─────────────────────────────────────
# XAI_API_KEY=
# GOOGLE_AI_API_KEY=
